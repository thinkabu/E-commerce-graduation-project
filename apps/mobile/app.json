{
  "expo": {
    "name": "mobile",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSFaceIDUsageDescription": "Ứng dụng sử dụng Face ID để đăng nhập nhanh và bảo mật hơn.",
        "LSApplicationQueriesSchemes": ["metamask", "ethereum", "https"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": false,
          "data": [
            { "scheme": "ethereum" },
            { "scheme": "metamask" }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-dev-client",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#eab308",
          "sounds": [],
          "androidMode": "default",
          "androidCollapsedTitle": "Thông báo mới",
          "iosDisplayInForeground": true
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-secure-store",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Cho phép $(PRODUCT_NAME) sử dụng Face ID để đăng nhập nhanh."
        }
      ]
    ],
    "notification": {
      "icon": "./assets/images/icon.png",
      "color": "#eab308",
      "androidMode": "default",
      "androidCollapsedTitle": "Thông báo mới"
    },
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
