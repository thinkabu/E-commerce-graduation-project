#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*) basedir=`cygpath -w "$basedir"`;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/mnt/d/DATN/apps/mobile/node_modules/@expo/xcpretty/build/node_modules:/mnt/d/DATN/apps/mobile/node_modules/@expo/xcpretty/node_modules:/mnt/d/DATN/apps/mobile/node_modules/@expo/node_modules:/mnt/d/DATN/apps/mobile/node_modules:/mnt/d/DATN/apps/node_modules:/mnt/d/DATN/node_modules:/mnt/d/node_modules:/mnt/d/DATN/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/mnt/d/DATN/apps/mobile/node_modules/@expo/xcpretty/build/node_modules:/mnt/d/DATN/apps/mobile/node_modules/@expo/xcpretty/node_modules:/mnt/d/DATN/apps/mobile/node_modules/@expo/node_modules:/mnt/d/DATN/apps/mobile/node_modules:/mnt/d/DATN/apps/node_modules:/mnt/d/DATN/node_modules:/mnt/d/node_modules:/mnt/d/DATN/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../@expo/xcpretty/build/cli.js" "$@"
else
  exec node  "$basedir/../@expo/xcpretty/build/cli.js" "$@"
fi
